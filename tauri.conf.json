{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LWT Desktop",
  "version": "0.1.0",
  "identifier": "io.github.lukasborges.learningwithtexts.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web:tauri",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web:tauri",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "title": "Learning with Texts",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset:; media-src 'self' data: blob:; style-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
